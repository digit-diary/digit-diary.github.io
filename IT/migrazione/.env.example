# === CONFIGURAZIONE SUPABASE SELF-HOSTED ===
# Copiare questo file come .env e modificare i valori

# Password del database PostgreSQL (scegliere una password sicura)
POSTGRES_PASSWORD=CambiaQuestaPasword123!

# JWT Secret: stringa casuale di 40+ caratteri
# Generare da: https://generate-secret.vercel.app/40
JWT_SECRET=cambia-questo-valore-con-una-stringa-casuale-lunga

# URL del sito (come sara' accessibile dall'esterno)
SITE_URL=http://10.0.1.50:3000
